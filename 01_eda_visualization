"""
Script 01: Exploratory Data Analysis & Visualization
This script fetches the pristine MIT-BIH Arrhythmia database directly from 
the PhysioNet cloud server using the official 'wfdb' library to avoid 
local text-encoding corruption and parsing errors.
"""

import wfdb
import matplotlib.pyplot as plt
import seaborn as sns
import numpy as np

def visualize_clinical_ecg(patient_id='106', num_samples=2000):
    sns.set_theme(style="whitegrid", context="paper", font_scale=1.2)
    print(f"Fetching pristine data for Patient {patient_id} from MIT-BIH cloud server...")
    
    try:
        # Fetch directly from PhysioNet database
        record = wfdb.rdrecord(patient_id, pn_dir='mitdb', sampfrom=0, sampto=num_samples)
        annotation = wfdb.rdann(patient_id, 'atr', pn_dir='mitdb', sampfrom=0, sampto=num_samples)
        
        signal = record.p_signal[:, 0]
        time_steps = np.arange(len(signal))
        ann_indices = annotation.sample
        ann_symbols = annotation.symbol
        
        plt.figure(figsize=(15, 5))
        sns.lineplot(x=time_steps, y=signal, color='#D62728', linewidth=1.5, label='Raw ECG Signal')
        
        has_n, has_v = False, False
        for idx, symbol in zip(ann_indices, ann_symbols):
            y_val = signal[idx]
            if symbol == 'N':
                plt.scatter(idx, y_val, color='#2ca02c', s=100, zorder=5, label='Normal (N)' if not has_n else "")
                plt.text(idx, y_val + 0.15, 'N', color='#2ca02c', fontsize=14, fontweight='bold', ha='center')
                has_n = True
            elif symbol == 'V':
                plt.scatter(idx, y_val, color='#ff7f0e', s=250, marker='*', zorder=6, label='PVC (V)')
                plt.text(idx, y_val + 0.2, 'V (Anomaly!)', color='#ff7f0e', fontsize=14, fontweight='bold', ha='center')
                has_v = True
                
        plt.title(f'Patient {patient_id} - Identification of Premature Ventricular Contractions (PVC)', fontsize=16, fontweight='bold')
        plt.xlabel('Sample Index (Time Step)', fontsize=12)
        plt.ylabel('Voltage (mV)', fontsize=12)
        
        handles, labels = plt.gca().get_legend_handles_labels()
        by_label = dict(zip(labels, handles))
        plt.legend(by_label.values(), by_label.keys(), loc='upper right')
        
        plt.tight_layout()
        plt.show()
        print("Visualization complete.")
        
    except Exception as e:
        print(f"Error fetching data from cloud: {e}")
        print("Please ensure you have an active internet connection and 'wfdb' is installed (pip install wfdb).")

if __name__ == "__main__":
    visualize_clinical_ecg(patient_id='106')
